{% extends 'layout.html.twig' %}

{% block page_title %}{{ 'user.settings.title_long'|trans }}{% endblock %}

{% block page_content %}
    <header>
        <h1>{{ 'user.settings.title_long'|trans }}</h1>
    </header>

    {{ form_start(form) }}

    <div class="ui-block">
        <div class="ui-block-heading">
            <h2>{{ 'user.settings.heading.public_profile'|trans }}</h2>
        </div>

        <div class="ui-block-content">
            {{ form_row(form.publicProfile) }}
            {{ form_row(form.aboutMe) }}
        </div>
    </div>

    <div class="ui-block">
        <div class="ui-block-heading">
            <h2>{{ 'user.settings.heading.change_password'|trans }}</h2>
        </div>

        <div class="ui-block-content">
            {{ form_row(form.currentPassword) }}
            {{ form_row(form.plainPassword) }}
        </div>
    </div>

    <div class="form-action-button">
        <button>{{ 'common.action.save'|trans }}</button>

        <button type="button" class="remove-button" command="show-modal" commandfor="remove-dialog">
            {{ 'user.remove.title'|trans }}
        </button>
    </div>

    {{ form_end(form) }}

    {% include 'common/remove_dialog.html.twig' with {
        remove_question: 'user.remove.text.confirmation'|trans,
        remove_post_url: path('user.remove'),
    } %}
{% endblock %}
